AEROC_ENV=development
AEROC_PROCESS_ROLE=api_scheduler
LOG_LEVEL=INFO
LOG_FORMAT=text
AEROC_WEB_WORKERS=1
SHUTDOWN_GRACE_SECONDS=90

API_TITLE=AeroC API
API_VERSION=1.0.0

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aeroc_db
DATABASE_USER=aeroc
DATABASE_PASSWORD=changeme
DATABASE_SSLMODE=prefer
DATABASE_CONNECT_TIMEOUT_SECONDS=5
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_LOCK_TIMEOUT_MS=5000
DATABASE_APPLICATION_NAME=aeroc-local
HEALTH_DATABASE_TIMEOUT_SECONDS=2

COLLECTION_INTERVAL_MINUTES=60
COLLECTION_RUN_ON_STARTUP=true
SCHEDULER_MISFIRE_GRACE_SECONDS=300
COLLECTION_STARTUP_GRACE_SECONDS=120
COLLECTION_STALE_AFTER_MINUTES=150

OPEN_METEO_BASE_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OPEN_METEO_TIMEOUT_SECONDS=20
OPEN_METEO_MAX_ATTEMPTS=3
OPEN_METEO_RETRY_BASE_SECONDS=1
OPEN_METEO_RETRY_MAX_SECONDS=8

# Production must use require, verify-ca, or verify-full. For verify-ca/full,
# mount the provider CA certificate and set DATABASE_SSLROOTCERT to its path.
